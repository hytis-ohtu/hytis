{
  "name": "hytis",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "install:all": "npm install && npm install --prefix backend && npm install --prefix frontend",
    "start:db": "npm run start:db --prefix backend",
    "seed:db": "npm run seed:db --prefix backend",
    "dev:backend": "npm run dev --prefix backend",
    "build:backend": "npm run build --prefix backend",
    "lint:backend": "npm run lint --prefix backend",
    "start:backend": "npm start --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "lint:frontend": "npm run lint --prefix frontend",
    "preview:frontend": "npm run preview --prefix frontend",
    "test:e2e": "playwright test",
    "test:e2e-report": "playwright show-report",
    "test:e2e:demo": "playwright test --project=demo",
    "test:backend": "npm run test --prefix backend",
    "coverage:backend": "npm run coverage --prefix backend",
    "test:frontend": "npm run test --prefix frontend",
    "coverage:frontend": "npm run coverage --prefix frontend",
    "test:all": "npm run test:frontend && npm run test:backend && npm run lint:backend && npm run lint:frontend && npm run test:e2e"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hytis-ohtu/hytis.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/hytis-ohtu/hytis/issues"
  },
  "homepage": "https://github.com/hytis-ohtu/hytis#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm"
    }
  }
}
